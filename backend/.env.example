# Local development overrides for the eter-agent backend.
# Copy to .env and fill in. Never commit a real .env.

ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]

# sqlite for dev; swap to postgresql+asyncpg://... for prod
DATABASE_URL=sqlite+aiosqlite:///./eter-agent.db

# Shared secret the Mac daemon and phone PWA present in the WS hello message.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
WS_SHARED_SECRET=CHANGE_ME_IN_PROD

# GitHub OAuth (for the PWA login flow). Create an OAuth App at
# https://github.com/settings/developers with the callback URL set to
# {PUBLIC_BASE_URL}/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Railway master token. PWA lets the HoD paste this; the backend forwards it
# to the Mac daemon's .env on first connection. (Railway does not support
# 3rd-party OAuth, so this is the simplest workable path.)
RAILWAY_MASTER_TOKEN=

# VAPID keys for web push notifications on the phone. Generate with:
#   pip install py-vapid
#   vapid --gen
# Then put the public key in the frontend's .env (VITE_VAPID_PUBLIC_KEY) and
# both keys here.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:you@example.com

PUBLIC_BASE_URL=http://localhost:8000

# Local development overrides for the eter-agent backend.
# Copy to .env and fill in. Never commit a real .env.

ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=*

# sqlite for dev; swap to postgresql+asyncpg://... for prod
DATABASE_URL=sqlite+aiosqlite:///./eter-agent.db

# Shared secret the Mac daemon and phone PWA present in the WS hello message.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
WS_SHARED_SECRET=CHANGE_ME_IN_PROD

PUBLIC_BASE_URL=http://localhost:8000
